<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | SBNM Polytechnic</title>
    <meta name="description" content="Shri Bhairavnath Nisarg Mandals Polytechnic Institute – Diploma in Engineering & Technology, Gevrai Tanda, Paithan Road, Aurangabad.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Poppins:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">
    <style>
        :root {
            --primary:       #1a5c38;
            --primary-light: #227a4a;
            --primary-dark:  #134429;
            --accent:        #d97706;
            --accent-light:  #f59e0b;
            --accent-dark:   #b45309;
            --dark:          #0f1c14;
            --text:          #1c2b1f;
            --muted:         #5a7a64;
            --bg:            #f6fbf7;
            --white:         #ffffff;
            --border:        #d4e6d8;
            --nav-h:         70px;
        }

        *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

        html { scroll-behavior: smooth; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        /* ── NAVBAR ── */
        .navbar {
            position: fixed;
            inset-block-start: 0; inset-inline: 0;
            height: var(--nav-h);
            z-index: 900;
            background: rgba(255,255,255,0.97);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border);
            box-shadow: 0 2px 16px rgba(26,92,56,0.07);
            transition: box-shadow 0.3s;
        }
        .navbar.scrolled { box-shadow: 0 4px 28px rgba(26,92,56,0.14); }

        .nav-inner {
            max-width: 1280px; margin: 0 auto;
            padding: 0 20px;
            height: 100%;
            display: flex; align-items: center; justify-content: space-between;
            gap: 16px;
        }

        .nav-brand {
            display: flex; align-items: center; gap: 10px;
            text-decoration: none; flex-shrink: 0;
        }
        .nav-logo {
            width: 46px; height: 46px; border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 1.15rem; font-weight: 800;
            box-shadow: 0 3px 10px rgba(26,92,56,0.3);
            flex-shrink: 0;
        }
        .nav-brand-text .name {
            font-family: 'Poppins', sans-serif;
            font-size: 0.82rem; font-weight: 700;
            color: var(--primary); line-height: 1.25; display: block;
        }
        .nav-brand-text .sub {
            font-size: 0.65rem; color: var(--accent-dark);
            font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;
        }

        .nav-links {
            display: flex; align-items: center; gap: 2px; list-style: none;
        }
        .nav-links a {
            padding: 8px 13px; text-decoration: none;
            color: var(--text); font-size: 0.84rem; font-weight: 500;
            border-radius: 8px; transition: all 0.2s; position: relative;
        }
        .nav-links a:hover { color: var(--primary); background: rgba(26,92,56,0.07); }
        .nav-links a.active {
            color: var(--primary); background: rgba(26,92,56,0.09);
            font-weight: 600;
        }
        .nav-links a.active::after {
            content: '';
            position: absolute; bottom: 4px; left: 13px; right: 13px;
            height: 2px; background: var(--accent); border-radius: 2px;
        }

        .nav-cta {
            display: flex; align-items: center; gap: 7px;
            padding: 9px 18px;
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            color: white !important; border-radius: 9px;
            font-weight: 700; font-size: 0.84rem;
            text-decoration: none; transition: all 0.3s;
            box-shadow: 0 4px 12px rgba(26,92,56,0.28);
            white-space: nowrap;
        }
        .nav-cta:hover { transform: translateY(-2px); box-shadow: 0 7px 18px rgba(26,92,56,0.38); }
        .nav-cta::after { display: none !important; }

        /* hamburger */
        .hamburger {
            display: none; flex-direction: column; gap: 5px;
            cursor: pointer; padding: 8px; background: transparent; border: none;
        }
        .hamburger span { display: block; width: 23px; height: 2px; background: var(--text); border-radius: 2px; transition: all 0.3s; }
        .hamburger.open span:nth-child(1) { transform: rotate(45deg) translateY(9px); }
        .hamburger.open span:nth-child(2) { opacity: 0; }
        .hamburger.open span:nth-child(3) { transform: rotate(-45deg) translateY(-9px); }

        /* Mobile drawer */
        .mobile-nav {
            display: none; position: fixed;
            top: var(--nav-h); left: 0; right: 0; bottom: 0;
            background: white; z-index: 899; overflow-y: auto;
            padding: 16px; flex-direction: column; gap: 4px;
            border-top: 1px solid var(--border);
            box-shadow: 0 8px 40px rgba(0,0,0,0.12);
            transform: translateX(100%);
            transition: transform 0.3s ease;
        }
        .mobile-nav.open { display: flex; transform: translateX(0); }
        .mobile-nav a {
            display: flex; align-items: center; gap: 12px;
            padding: 13px 16px; text-decoration: none;
            color: var(--text); font-weight: 500; border-radius: 10px;
            transition: background 0.2s; font-size: 0.95rem;
        }
        .mobile-nav a i { width: 20px; color: var(--primary); }
        .mobile-nav a:hover, .mobile-nav a.active { background: rgba(26,92,56,0.07); color: var(--primary); }
        .mobile-nav .mob-cta {
            background: linear-gradient(135deg, var(--accent), var(--accent-dark));
            color: white !important;
            margin-top: 8px; font-weight: 700; justify-content: center;
        }
        .mobile-nav .mob-cta i { color: white; }
        .mobile-nav .mob-divider { height: 1px; background: var(--border); margin: 8px 0; }

        /* ── MAIN ── */
        main { flex-grow: 1; margin-top: var(--nav-h); }

        /* ── FOOTER ── */
        footer {
            background: linear-gradient(160deg, var(--dark) 0%, #0a1a0d 100%);
            color: #8fb898; padding: 56px 0 0; margin-top: 80px;
        }
        .footer-grid {
            max-width: 1280px; margin: 0 auto; padding: 0 20px;
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr;
            gap: 40px;
        }
        .f-brand .logo-row { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
        .f-logo {
            width: 44px; height: 44px; border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 1.1rem; font-weight: 800; flex-shrink: 0;
        }
        .f-bname { font-family: 'Poppins'; font-size: 0.9rem; font-weight: 700; color: white; line-height: 1.3; }
        .f-bsub { font-size: 0.65rem; color: var(--accent-light); text-transform: uppercase; letter-spacing: 0.05em; }
        .f-brand p { font-size: 0.85rem; line-height: 1.8; margin-bottom: 18px; }
        .f-social { display: flex; gap: 10px; }
        .f-social a {
            width: 34px; height: 34px;
            background: rgba(255,255,255,0.07);
            border-radius: 8px; display: flex; align-items: center; justify-content: center;
            color: #8fb898; text-decoration: none; transition: all 0.2s;
        }
        .f-social a:hover { background: var(--accent); color: white; transform: translateY(-2px); }
        .f-col h4 {
            color: white; font-size: 0.8rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 18px;
        }
        .f-col ul { list-style: none; }
        .f-col ul li { margin-bottom: 9px; }
        .f-col ul li a {
            color: #8fb898; text-decoration: none; font-size: 0.84rem;
            transition: color 0.2s; display: flex; align-items: center; gap: 6px;
        }
        .f-col ul li a:hover { color: var(--accent-light); }
        .f-contact-item { display: flex; gap: 10px; margin-bottom: 11px; font-size: 0.83rem; line-height: 1.5; }
        .f-contact-item i { color: var(--accent-light); margin-top: 2px; flex-shrink: 0; width: 14px; }
        .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.07);
            margin-top: 48px; padding: 18px 20px; font-size: 0.78rem;
        }
        .footer-bottom .fb-inner {
            max-width: 1280px; margin: 0 auto;
            display: flex; justify-content: space-between;
            align-items: center; flex-wrap: wrap; gap: 8px;
        }

        /* ── FLOATING CHAT ── */
        .fab-chat {
            position: fixed; bottom: 24px; right: 24px;
            width: 56px; height: 56px; border-radius: 50%;
            background: linear-gradient(135deg, var(--accent), var(--accent-dark));
            color: white; font-size: 1.3rem;
            display: flex; align-items: center; justify-content: center;
            text-decoration: none; z-index: 800;
            box-shadow: 0 6px 20px rgba(217,119,6,0.45);
            animation: fab-pulse 3s ease infinite;
            transition: transform 0.3s;
        }
        .fab-chat:hover { transform: scale(1.12) rotate(-8deg); }
        @keyframes fab-pulse {
            0%, 100% { box-shadow: 0 6px 20px rgba(217,119,6,0.45); }
            50% { box-shadow: 0 6px 32px rgba(217,119,6,0.7); }
        }

        /* ── SHARED UTILITIES ── */
        .pw { max-width: 1280px; margin: 0 auto; padding: 0 20px; }
        .sec { padding: 72px 0; }
        .sec-sm { padding: 48px 0; }

        .sec-tag {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 5px 14px; border-radius: 100px;
            background: rgba(26,92,56,0.08); color: var(--primary);
            font-size: 0.75rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 14px;
        }
        .sec-tag.gold { background: rgba(217,119,6,0.1); color: var(--accent-dark); }

        .sec-h {
            font-family: 'Poppins', sans-serif;
            font-size: clamp(1.7rem, 4vw, 2.8rem);
            font-weight: 800; color: var(--dark);
            line-height: 1.2; margin-bottom: 14px;
        }
        .sec-h span { color: var(--accent); }
        .sec-sub { color: var(--muted); font-size: 1rem; max-width: 580px; line-height: 1.75; }
        .sec-center { text-align: center; }
        .sec-center .sec-sub { margin: 0 auto; }

        /* btn */
        .btn { display: inline-flex; align-items: center; gap: 8px; padding: 13px 26px; border-radius: 10px; font-weight: 700; font-size: 0.9rem; text-decoration: none; transition: all 0.3s; }
        .btn-primary { background: linear-gradient(135deg, var(--primary), var(--primary-light)); color: white; box-shadow: 0 5px 16px rgba(26,92,56,0.28); }
        .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 10px 26px rgba(26,92,56,0.38); }
        .btn-outline { border: 2px solid rgba(26,92,56,0.22); color: var(--primary); background: white; }
        .btn-outline:hover { border-color: var(--primary); background: rgba(26,92,56,0.05); transform: translateY(-2px); }
        .btn-accent { background: linear-gradient(135deg, var(--accent), var(--accent-dark)); color: white; box-shadow: 0 5px 16px rgba(217,119,6,0.3); }
        .btn-accent:hover { transform: translateY(-3px); box-shadow: 0 10px 26px rgba(217,119,6,0.4); }

        /* Card base */
        .card { background: white; border-radius: 18px; border: 1px solid var(--border); transition: transform 0.3s, box-shadow 0.3s; }
        .card:hover { transform: translateY(-5px); box-shadow: 0 18px 48px rgba(26,92,56,0.1); }

        /* ── MOBILE ── */
        @media (max-width: 900px) {
            .nav-links, .nav-cta { display: none; }
            .hamburger { display: flex; }
            .footer-grid { grid-template-columns: 1fr 1fr; gap: 28px; }
        }
        @media (max-width: 520px) {
            .footer-grid { grid-template-columns: 1fr; }
            .footer-bottom .fb-inner { flex-direction: column; text-align: center; }
        }
    </style>
</head>
<body>

